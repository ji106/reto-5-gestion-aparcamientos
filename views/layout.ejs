<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="min-vh-100 d-flex flex-column">
    <nav class="navbar navbar-expand-lg navbar-light bg-white navbar-bp py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-2 mx-auto mx-lg-0" href="/">
                <i class="bi bi-p-circle-fill text-primary fs-1 me-2"></i>ParkTrack
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse text-center" id="nav-menu">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link nav-link-custom fw-bold fs-5 text-dark px-3" href="/">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom fw-bold fs-5 text-dark px-3" href="/history">Historial</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom fw-bold fs-5 text-dark px-3" href="/contact">Contacto</a></li>
                </ul>
                <% if (user) { %>
                    <span class="me-3 text-muted">
                        <i class="bi bi-person-circle me-1"></i><%= user.username %>
                    </span>
                    <a class="btn btn-park" href="/logout">
                        <i class="bi bi-box-arrow-right me-1"></i>Cerrar Sesión
                    </a>
                <% } else { %>
                    <a class="btn btn-park" href="/login">
                        <i class="bi bi-person me-1"></i>Iniciar Sesión
                    </a>
                <% } %>
            </div>
        </div>
    </nav>

    <%- body %>

    <footer class="text-white mt-auto footer-bp" style="background-color: #0a3d6b;">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="footer-icon">
                            <i class="bi bi-shield-check text-white"></i>
                        </div>
                        <span class="fw-bold fs-5 text-white footer-title">Legal</span>
                    </div>
                    <ul class="list-unstyled lh-lg">
                        <li><a class="footer-link" href="#">Política de privacidad</a></li>
                        <li><a class="footer-link" href="#">Términos de uso</a></li>
                        <li><a class="footer-link" href="#">Aviso legal</a></li>
                        <li><a class="footer-link" href="#">Cookies</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="footer-icon">
                            <i class="bi bi-envelope text-white"></i>
                        </div>
                        <span class="fw-bold fs-5 text-white">Contacto</span>
                    </div>
                    <ul class="list-unstyled lh-lg">
                        <li><a class="footer-link" href="#">info@parktrack.com</a></li>
                        <li><a class="footer-link" href="/contact">Formulario de contacto</a></li>
                        <li><a class="footer-link" href="#">Soporte técnico</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="footer-icon">
                            <i class="bi bi-p-circle text-white"></i>
                        </div>
                        <span class="fw-bold fs-5 text-white">ParkTrack</span>
                    </div>
                    <ul class="list-unstyled lh-lg">
                        <li><a class="footer-link" href="/">Inicio</a></li>
                        <li><a class="footer-link" href="/history">Historial</a></li>
                        <li><a class="footer-link" href="/contact">Contacto</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div style="background-color: #091e47;">
            <div class="container py-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center gap-3">
                    <i class="bi bi-p-circle-fill text-primary fs-2" style="font-size: 48;"></i>
                    <span class="fw-bold fs-5 text-white">ParkTrack</span>
                </div>
                <div>
                    <span class="text-white-50 small d-block">© 2026 ParkTrack. Todos los derechos reservados.</span>
                    <span class="text-white-50 small d-block">Control inteligente de aparcamientos</span>
                </div>
                <div class="d-flex gap-3">
                    <a class="footer-link" href="#">Aviso legal</a>
                    <a class="footer-link" href="#">Privacidad</a>
                    <a class="footer-link" href="#">Cookies</a>
                    <a class="footer-link" href="/contact">Contacto</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/javascripts/main.js"></script>
</body>
</html>