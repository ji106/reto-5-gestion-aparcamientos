<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" href="/">🅿 ParkTrack</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav-menu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="/history">Historial</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contact">Contacto</a></li>
                </ul>
                <% if (user) { %>
                    <span class="me-3 text-muted">👤 <%= user.username %></span>
                    <a class="btn btn-sm btn-outline-primary" href="/logout">Cerrar Sesión</a>
                <% } else { %>
                    <a class="btn btn-sm btn-primary" href="/login">Iniciar Sesión</a>
                <% } %>
            </div>
        </div>
    </nav>

    <%- body %>

    <footer class="bg-primary text-white py-4 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h6 class="fw-bold">🅿 ParkTrack</h6>
                    <p class="text-white-50 small">Nunca pierdas tu coche aparcado.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold">Legal</h6>
                    <ul class="list-unstyled small">
                        <li><a class="text-white-50 text-decoration-none" href="#">Política de privacidad</a></li>
                        <li><a class="text-white-50 text-decoration-none" href="#">Términos de uso</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold">Contacto</h6>
                    <ul class="list-unstyled small">
                        <li><a class="text-white-50 text-decoration-none" href="#">info@parktrack.com</a></li>
                        <li><a class="text-white-50 text-decoration-none" href="#">Soporte</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <hr class="opacity-25">
        <p class="text-center text-white-50 small mb-0">© 2026 ParkTrack. Todos los derechos reservados.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/javascripts/main.js"></script>
</body>
</html>