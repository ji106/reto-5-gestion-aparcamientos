<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="fw-bold mb-4">Contacto</h2>
            <form action="/contact" method="post">
                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" type="text" name="name" placeholder="Tu nombre">
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input class="form-control" type="email" name="email" placeholder="Tu email">
                </div>
                <div class="mb-3">
                    <label class="form-label">Mensaje</label>
                    <textarea class="form-control" name="message" rows="5" placeholder="Tu mensaje"></textarea>
                </div>
                <button class="btn btn-primary w-100" type="submit">Enviar</button>
            </form>
        </div>
    </div>
</div>