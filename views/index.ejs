<div class="d-flex flex-column" style="min-height: calc(100vh - 120px);">
  <section class="container py-5">
    <div class="row align-items-center">
      <div class="col-12 col-lg-8 text-center">
        <img class="img-fluid" src="/images/parking.png" alt="Parking">
      </div>
      <div class="col-12 col-lg-4">
        <h1 class="fw-bold display-6">Localiza tu coche <br> al instante</h1>
        <hr class="hero-divider" style="width: 70px; height: 10px;">
        <p class="fs-5">Guarda la ubicación de tu vehículo con un solo clic y encuéntralo fácilmente cuando lo necesites.</p>
        <p class="fs-5">Accede a tu <strong>historial de aparcamientos</strong> y sincroniza tus datos desde cualquier dispositivo.</p>
        <a class="btn btn-park btn-lg mt-2 px-4 py-3" href="#map">Aparcar aquí</a>
      </div>
    </div>
  </section>
  <section class="container py-5" id="map-section">
    <div class="row g-4">
      <div class="col-md-8">
        <div id="map" style="height: 450px; border-radius: 12px;"></div>
      </div>
      <div class="col-md-4">
        <div class="card shadow-sm h-100">
          <div class="card-body d-flex flex-column gap-3">
            <h5 class="fw-bold">Panel de control</h5>
            <div class="alert alert-secondary" id="status">No hay aparcamiento activo.</div>
            <div class="d-none" id="info">
              <p class="mb-1"><strong>Distancia:</strong> <span id="distance">--</span></p>
              <p class="mb-1"><strong>Tiempo:</strong> <span id="time">--</span></p>
            </div>
            <button class="btn btn-park px-4 py-3" id="btn-park">Guardar aparcamiento</button>
            <button class="btn btn-danger d-none" id="btn-finish">
              <i class="bi bi-x-circle me-1"></i>Finalizar aparcamiento
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>